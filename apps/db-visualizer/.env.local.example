# Use read-only database credentials in this app (or rely on packages/database/.env loaded by @repo/database).
DATABASE_URL=
DIRECT_URL=

# If you see Postgres 53300 while other monorepo apps are running, lower pool size (this app’s process only
# if set here and not overridden by packages/database/.env — otherwise set DATABASE_POOL_MAX there).
# DATABASE_POOL_MAX=1
