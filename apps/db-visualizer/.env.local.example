# Use read-only database credentials in this app (or rely on packages/database/.env loaded by @repo/database).
DATABASE_URL=
DIRECT_URL=

# Optional: protect GET /api/efl/internal/sync-all (middleware + route). If set, requests must send header x-efl-internal-sync: <secret>.
# For browser polling, set the same value in NEXT_PUBLIC_EFL_INTERNAL_SYNC_SECRET (internal deploys only — exposes secret to the client bundle).
EFL_INTERNAL_SYNC_SECRET=
NEXT_PUBLIC_EFL_INTERNAL_SYNC_SECRET=

# If you see Postgres 53300 (“remaining connection slots are reserved for roles with the SUPERUSER attribute”),
# the database is at its non-superuser connection cap. Prefer a pooled DATABASE_URL (PgBouncer / Neon pooler /
# Supabase pooler / PlanetScale pooler URL). Per Vercel/serverless instance, cap the in-process pool:
# DATABASE_POOL_MAX=1
# (Set on each app that shares this DB, or in packages/database/.env for local dev, so totals stay under your tier.)
