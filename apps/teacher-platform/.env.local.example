# NextAuth / Auth.js v5
# Required for session signing. Use: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
# Backward-compatible alias supported by Auth.js:
# AUTH_SECRET=replace-with-a-long-random-string
# Optional: defaults to request host. Set for custom base URL.
NEXTAUTH_URL=http://localhost:3001

# Cross-app routing (required for sign-in redirect)
NEXT_PUBLIC_LANDING_PAGE_URL=http://localhost:3000

# Database (same DB as landing / student / curriculum for a unified ecosystem)
# Hosted / Accelerate patterns: packages/database/.env.example and docs/operations.md
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers
# Optional: DATABASE_POOL_MAX=1

# Curriculum platform integration (published curriculum snapshots)
CURRICULUM_PLATFORM_URL=http://localhost:3003
CURRICULUM_API_SHARED_SECRET=
