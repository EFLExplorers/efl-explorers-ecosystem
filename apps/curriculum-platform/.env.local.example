NEXTAUTH_URL=http://localhost:3003
# Required in all environments. Generate via `openssl rand -base64 32`.
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Postgres (same rules as packages/database — see docs/operations.md).
# Local: match other apps. Hosted: direct URL on DIRECT_URL; pooler or Accelerate on DATABASE_URL when applicable.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers
# Optional: DATABASE_POOL_MAX=1

# Initial bootstrap email allowed to create first manager account.
# Comma-separated list.
CURRICULUM_BOOTSTRAP_ALLOWLIST=owner@example.com

# Optional shared secret required by /api/public routes when set.
CURRICULUM_API_SHARED_SECRET=
