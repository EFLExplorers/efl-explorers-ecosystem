NEXTAUTH_URL=http://localhost:3003
# Required in all environments. Generate via `openssl rand -base64 32`.
NEXTAUTH_SECRET=

# Postgres connection strings.
DATABASE_URL=
DIRECT_URL=

# Initial bootstrap email allowed to create first manager account.
# Comma-separated list.
CURRICULUM_BOOTSTRAP_ALLOWLIST=owner@example.com

# Optional shared secret required by /api/public routes when set.
CURRICULUM_API_SHARED_SECRET=
