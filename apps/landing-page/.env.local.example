# NextAuth
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Database (required — landing uses @repo/database for auth and content APIs)
# Use the same Postgres database as other apps locally; on Vercel set both to your hosted URLs.
# PlanetScale Postgres / pooler / Accelerate: see packages/database/.env.example and docs/operations.md
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers
# Optional per-instance pool cap (serverless / shared pooler): DATABASE_POOL_MAX=1

# Public URLs used for redirects between apps
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_LANDING_PAGE_URL=http://localhost:3000
NEXT_PUBLIC_TEACHER_URL=http://localhost:3001
NEXT_PUBLIC_STUDENT_URL=http://localhost:3002

# API and auth helpers
EFL_API_KEY=replace-with-shared-api-key
BCRYPT_SALT_ROUNDS=10
