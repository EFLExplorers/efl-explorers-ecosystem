generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "curriculum", "shared", "students", "teachers"]
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String?
  email               String?              @unique
  emailVerified       DateTime?            @map("email_verified")
  image               String?
  passwordHash        String?              @map("password_hash")
  role                UserRole             @default(student)
  approved            Boolean              @default(false)
  firstName           String?              @map("first_name")
  lastName            String?              @map("last_name")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")
  subscriptionTier    SubscriptionTier     @default(free) @map("subscription_tier")
  accounts            Account[]
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]
  ssoTokens           SsoToken[]

  @@map("users")
  @@schema("auth")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("auth")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("auth")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("auth")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
  @@schema("auth")
}

model SsoToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  platform  UserRole
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sso_tokens")
  @@schema("auth")
}

model Page {
  id              String         @id @default(uuid()) @db.Uuid
  route           String         @unique
  title           String?
  metaDescription String?        @map("meta_description")
  layout          String         @default("default") @db.VarChar(64)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at")
  contentItems    ContentItem[]
  sections        PageSection[]
  routeSections   RouteSection[]

  @@map("pages")
  @@schema("shared")
}

model ContentItem {
  id                  String                @id @default(uuid()) @db.Uuid
  pageId              String?               @map("page_id") @db.Uuid
  sectionKey          String?               @map("section_key") @db.VarChar(128)
  contentType         String                @map("content_type") @db.VarChar(128)
  slug                String?               @unique
  title               String?
  subtitle            String?
  description         String?
  content             Json?
  metadata            Json?
  sortOrder           Int                   @default(0) @map("sort_order")
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at")
  page                Page?                 @relation(fields: [pageId], references: [id], onDelete: Cascade)
  childRelationships  ContentRelationship[] @relation("ContentChild")
  parentRelationships ContentRelationship[] @relation("ContentParent")

  @@index([contentType, active])
  @@index([slug])
  @@index([pageId, contentType, active, sortOrder])
  @@map("content_items")
  @@schema("shared")
}

model PageSection {
  id          String   @id @default(uuid()) @db.Uuid
  pageId      String?  @map("page_id") @db.Uuid
  sectionKey  String   @map("section_key") @db.VarChar(128)
  sectionType String   @default("content") @map("section_type") @db.VarChar(64)
  title       String?
  subtitle    String?
  heading     String?
  subheading  String?
  body        String?
  ctaLabel    String?  @map("cta_label")
  ctaHref     String?  @map("cta_href")
  content     Json?
  settings    Json?
  data        Json?
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  page        Page?    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, sectionKey])
  @@index([pageId, sectionKey])
  @@index([active, sortOrder])
  @@map("page_sections")
  @@schema("shared")
}

model SiteSection {
  id          String   @id @default(uuid()) @db.Uuid
  sectionKey  String   @unique @map("section_key") @db.VarChar(128)
  sectionType String   @default("content") @map("section_type") @db.VarChar(64)
  content     Json?
  settings    Json?
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([active, sortOrder])
  @@map("site_sections")
  @@schema("shared")
}

model RouteSection {
  id              String   @id @default(uuid()) @db.Uuid
  pageId          String   @map("page_id") @db.Uuid
  sectionKey      String   @map("section_key") @db.VarChar(128)
  sectionType     String   @default("content") @map("section_type") @db.VarChar(64)
  expectedContent Json?    @map("expected_content")
  notes           String?
  sortOrder       Int      @default(0) @map("sort_order")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, sectionKey])
  @@index([pageId])
  @@map("route_sections")
  @@schema("shared")
}

model ContentRelationship {
  id               String      @id @default(uuid()) @db.Uuid
  parentId         String      @map("parent_id") @db.Uuid
  childId          String      @map("child_id") @db.Uuid
  relationshipType String      @map("relationship_type") @db.VarChar(128)
  sortOrder        Int         @default(0) @map("sort_order")
  createdAt        DateTime    @default(now()) @map("created_at")
  child            ContentItem @relation("ContentChild", fields: [childId], references: [id], onDelete: Cascade)
  parent           ContentItem @relation("ContentParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId, relationshipType])
  @@map("content_relationships")
  @@schema("shared")
}

model MediaAsset {
  id           String   @id @default(uuid()) @db.Uuid
  filename     String
  originalName String   @map("original_name")
  url          String
  altText      String?  @map("alt_text")
  caption      String?
  mimeType     String   @map("mime_type")
  sizeBytes    Int?     @map("size_bytes")
  dimensions   Json?
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("media_assets")
  @@schema("shared")
}

model Faq {
  id        String   @id @default(uuid()) @db.Uuid
  category  String?
  question  String?
  answer    String?
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("faqs")
  @@schema("shared")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  role      String?
  title     String?
  imageUrl  String?  @map("image_url")
  bio       String?
  expertise Json?
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("team_members")
  @@schema("shared")
}

model AboutStat {
  id        String   @id @default(uuid()) @db.Uuid
  number    String?
  label     String?
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("about_stats")
  @@schema("shared")
}

model CoreValue {
  id          String   @id @default(uuid()) @db.Uuid
  icon        String?
  title       String?
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("core_values")
  @@schema("shared")
}

model LessonModule {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String?
  colorToken          String?  @map("color_token")
  recommendedStudents String?  @map("recommended_students")
  description         String?
  lessonsSummary      String?  @map("lessons_summary")
  durationSummary     String?  @map("duration_summary")
  sortOrder           Int      @default(0) @map("sort_order")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("lesson_modules")
  @@schema("shared")
}

model TeacherBenefit {
  id          String   @id @default(uuid()) @db.Uuid
  title       String?
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("teacher_benefits")
  @@schema("shared")
}

model Testimonial {
  id         String   @id @default(uuid()) @db.Uuid
  quote      String?
  authorName String?  @map("author_name")
  authorRole String?  @map("author_role")
  sortOrder  Int      @default(0) @map("sort_order")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("testimonials")
  @@schema("shared")
}

model TeacherUserMapping {
  id         Int      @id @default(autoincrement())
  authUserId String   @unique @map("auth_user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("teacher_user_mappings")
  @@schema("teachers")
}

model StudentUserMapping {
  id         Int      @id @default(autoincrement())
  authUserId String   @unique @map("auth_user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("student_user_mappings")
  @@schema("students")
}

model Student {
  id               Int      @id @default(autoincrement())
  fullName         String   @map("full_name")
  email            String?
  level            String
  unitId           String   @map("unit_id")
  nativeLanguage   String?  @map("native_language")
  guardianName     String?  @map("guardian_name")
  guardianContact  String?  @map("guardian_contact")
  attendanceRate   Float?   @map("attendance_rate")
  performanceLevel String?  @map("performance_level")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("students")
  @@schema("teachers")
}

model Lesson {
  id              Int              @id @default(autoincrement())
  title           String
  subject         String
  description     String?
  classId         String           @map("class_id")
  date            DateTime
  startTime       String           @map("start_time")
  endTime         String           @map("end_time")
  location        String?
  status          String?          @db.VarChar(64)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  lessonMaterials LessonMaterial[]

  @@map("lessons")
  @@schema("teachers")
}

model Curriculum {
  id          Int      @id @default(autoincrement())
  title       String
  subject     String
  level       String
  description String?
  objectives  String?
  units       Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("curriculum")
  @@schema("teachers")
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  location    String?
  type        String?  @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("events")
  @@schema("teachers")
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("messages")
  @@schema("teachers")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  priority  String?  @db.VarChar(64)
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("announcements")
  @@schema("teachers")
}

model Task {
  id        Int       @id @default(autoincrement())
  title     String
  completed Boolean   @default(false)
  dueDate   DateTime? @map("due_date")
  userId    Int       @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("tasks")
  @@schema("teachers")
}

model Material {
  id              Int              @id @default(autoincrement())
  title           String
  description     String?
  category        String
  url             String
  createdBy       Int              @map("created_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  kind            String           @default("other") @db.VarChar(64)
  mimeType        String?          @map("mime_type")
  sizeBytes       Int?             @map("size_bytes")
  lessonMaterials LessonMaterial[]

  @@map("materials")
  @@schema("teachers")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  category  String?  @db.VarChar(128)
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  starred   Boolean  @default(false)

  @@map("bookmarks")
  @@schema("teachers")
}

model LessonMaterial {
  id         Int      @id @default(autoincrement())
  lessonId   Int      @map("lesson_id")
  materialId Int      @map("material_id")
  createdAt  DateTime @default(now()) @map("created_at")
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([lessonId, materialId])
  @@map("lesson_materials")
  @@schema("teachers")
}

model CurriculumManager {
  id                 String                      @id @default(uuid()) @db.Uuid
  email              String                      @unique
  name               String
  passwordHash       String                      @map("password_hash")
  isActive           Boolean                     @default(true) @map("is_active")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @default(now()) @updatedAt @map("updated_at")
  invitesAccepted    CurriculumInvite[]          @relation("CurriculumInviteAcceptedBy")
  invitesSent        CurriculumInvite[]          @relation("CurriculumInviteSentBy")
  levelsCreated      CurriculumLevel[]           @relation("CurriculumLevelCreatedBy")
  levelsUpdated      CurriculumLevel[]           @relation("CurriculumLevelUpdatedBy")
  programs           CurriculumProgram[]
  snapshotsPublished CurriculumPublishSnapshot[]
  unitsCreated       CurriculumUnit[]            @relation("CurriculumUnitCreatedBy")
  unitsUpdated       CurriculumUnit[]            @relation("CurriculumUnitUpdatedBy")

  @@map("managers")
  @@schema("curriculum")
}

model CurriculumInvite {
  id                  String             @id @default(uuid()) @db.Uuid
  email               String             @unique
  invitedByManagerId  String?            @map("invited_by_manager_id") @db.Uuid
  acceptedByManagerId String?            @map("accepted_by_manager_id") @db.Uuid
  expiresAt           DateTime?          @map("expires_at")
  acceptedAt          DateTime?          @map("accepted_at")
  revokedAt           DateTime?          @map("revoked_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at")
  acceptedByManager   CurriculumManager? @relation("CurriculumInviteAcceptedBy", fields: [acceptedByManagerId], references: [id])
  invitedByManager    CurriculumManager? @relation("CurriculumInviteSentBy", fields: [invitedByManagerId], references: [id])

  @@index([acceptedAt, revokedAt])
  @@map("invites")
  @@schema("curriculum")
}

model CurriculumProgram {
  id                 Int               @id @default(autoincrement())
  slug               String            @unique @db.VarChar(180)
  title              String
  description        String?
  isArchived         Boolean           @default(false) @map("is_archived")
  createdByManagerId String            @map("created_by_manager_id") @db.Uuid
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @default(now()) @updatedAt @map("updated_at")
  levels             CurriculumLevel[]
  createdByManager   CurriculumManager @relation(fields: [createdByManagerId], references: [id])

  @@index([isArchived, updatedAt])
  @@map("programs")
  @@schema("curriculum")
}

model CurriculumLevel {
  id                 Int                         @id @default(autoincrement())
  programId          Int                         @map("program_id")
  slug               String                      @db.VarChar(180)
  title              String
  orderIndex         Int                         @default(0) @map("order_index")
  lastPublishedAt    DateTime?                   @map("last_published_at")
  createdByManagerId String                      @map("created_by_manager_id") @db.Uuid
  updatedByManagerId String?                     @map("updated_by_manager_id") @db.Uuid
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @default(now()) @updatedAt @map("updated_at")
  status             CurriculumLevelStatus       @default(draft)
  createdByManager   CurriculumManager           @relation("CurriculumLevelCreatedBy", fields: [createdByManagerId], references: [id])
  program            CurriculumProgram           @relation(fields: [programId], references: [id], onDelete: Cascade)
  updatedByManager   CurriculumManager?          @relation("CurriculumLevelUpdatedBy", fields: [updatedByManagerId], references: [id])
  snapshots          CurriculumPublishSnapshot[]
  units              CurriculumUnit[]

  @@unique([programId, slug])
  @@index([programId, orderIndex])
  @@index([status, lastPublishedAt])
  @@map("levels")
  @@schema("curriculum")
}

model CurriculumUnit {
  id                 Int                             @id @default(autoincrement())
  levelId            Int                             @map("level_id")
  slug               String                          @db.VarChar(220)
  title              String
  summary            String?
  storyMarkdown      String                          @default("") @map("story_markdown")
  mediaManifest      Json?                           @map("media_manifest")
  assignmentConfig   Json?                           @map("assignment_config")
  estimatedMinutes   Int?                            @map("estimated_minutes")
  orderIndex         Int                             @default(0) @map("order_index")
  isArchived         Boolean                         @default(false) @map("is_archived")
  createdByManagerId String                          @map("created_by_manager_id") @db.Uuid
  updatedByManagerId String?                         @map("updated_by_manager_id") @db.Uuid
  createdAt          DateTime                        @default(now()) @map("created_at")
  updatedAt          DateTime                        @default(now()) @updatedAt @map("updated_at")
  snapshotUnits      CurriculumPublishSnapshotUnit[]
  createdByManager   CurriculumManager               @relation("CurriculumUnitCreatedBy", fields: [createdByManagerId], references: [id])
  level              CurriculumLevel                 @relation(fields: [levelId], references: [id], onDelete: Cascade)
  updatedByManager   CurriculumManager?              @relation("CurriculumUnitUpdatedBy", fields: [updatedByManagerId], references: [id])

  @@unique([levelId, slug])
  @@index([levelId, orderIndex])
  @@index([isArchived])
  @@map("units")
  @@schema("curriculum")
}

model CurriculumPublishSnapshot {
  id                   String                          @id @default(uuid()) @db.Uuid
  levelId              Int                             @map("level_id")
  version              Int
  isCurrent            Boolean                         @default(false) @map("is_current")
  publishedAt          DateTime                        @map("published_at")
  publishedByManagerId String                          @map("published_by_manager_id") @db.Uuid
  snapshotPayload      Json?                           @map("snapshot_payload")
  createdAt            DateTime                        @default(now()) @map("created_at")
  units                CurriculumPublishSnapshotUnit[]
  level                CurriculumLevel                 @relation(fields: [levelId], references: [id], onDelete: Cascade)
  publishedByManager   CurriculumManager               @relation(fields: [publishedByManagerId], references: [id])

  @@unique([levelId, version])
  @@index([levelId, isCurrent])
  @@map("publish_snapshots")
  @@schema("curriculum")
}

model CurriculumPublishSnapshotUnit {
  id               Int                       @id @default(autoincrement())
  snapshotId       String                    @map("snapshot_id") @db.Uuid
  sourceUnitId     Int                       @map("source_unit_id")
  orderIndex       Int                       @map("order_index")
  slug             String                    @db.VarChar(220)
  title            String
  summary          String?
  storyMarkdown    String                    @map("story_markdown")
  estimatedMinutes Int?                      @map("estimated_minutes")
  mediaManifest    Json?                     @map("media_manifest")
  assignmentConfig Json?                     @map("assignment_config")
  createdAt        DateTime                  @default(now()) @map("created_at")
  snapshot         CurriculumPublishSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  sourceUnit       CurriculumUnit            @relation(fields: [sourceUnitId], references: [id])

  @@unique([snapshotId, sourceUnitId])
  @@index([snapshotId, orderIndex])
  @@map("publish_snapshot_units")
  @@schema("curriculum")
}

enum UserRole {
  student
  teacher

  @@schema("auth")
}

enum SubscriptionTier {
  free
  premium

  @@schema("auth")
}

enum CurriculumLevelStatus {
  draft
  published
  archived

  @@schema("curriculum")
}
