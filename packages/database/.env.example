# Primary connection used by app runtime and Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers

# Direct Postgres URL for migrations/seeds (`db:apply-sql-migrations`, seed scripts).
# Often the same as DATABASE_URL locally; for hosted Postgres (e.g. PlanetScale Postgres),
# use the provider's "direct" URL here and optionally a pooler URL for DATABASE_URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/efl_explorers

# --- PlanetScale Postgres (example shape only; use real values from the dashboard) ---
# Hosts look like: <region>.pg.psdb.cloud — credentials use prefixes such as pscale_api_* / pscale_pw_*.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.pg.psdb.cloud:5432/postgres?sslmode=verify-full&sslrootcert=system
# DIRECT_URL=postgresql://USER:PASSWORD@HOST.pg.psdb.cloud:5432/postgres?sslmode=verify-full&sslrootcert=system
# For Prisma Accelerate instead of raw postgres at runtime, DATABASE_URL may be prisma://… or prisma+postgres://… (see docs/operations.md).

# Optional: cap `pg` pool size per Node/serverless instance (defaults: prod 10, dev 2; tighter if the URL has
# `pgbouncer=true` or `connection_limit=N`). Each running app process has its own pool — totals add up. If your
# pooler only allows e.g. 2 client connections, use DATABASE_POOL_MAX=1 and run at most two Node processes, or
# one process with DATABASE_POOL_MAX=2 and nothing else hitting the same pooler.
# DATABASE_POOL_MAX=1

# Optional: runtime-only Prisma Accelerate — many app instances talk to Accelerate; it pools toward Postgres so
# you use fewer direct DB sessions (keep DIRECT_URL=postgresql://… for migrate, seeds, and SQL scripts).
# DATABASE_URL=prisma://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_KEY
# DIRECT_URL=postgresql://...planetscale or pooler URL Prisma Accelerate is configured to use...

# Optional seed values
BCRYPT_SALT_ROUNDS=10
DEV_USER_EMAIL=teacher@example.com
DEV_USER_PASSWORD=change-me
DEV_USER_FIRST_NAME=Dev
DEV_USER_LAST_NAME=Teacher
# Optional override if you prefer full display name explicitly
DEV_USER_NAME=Dev Teacher

# Preferred role-specific seed values (teacher + student)
DEV_TEACHER_EMAIL=dev@example.com
DEV_TEACHER_PASSWORD=Password1!
DEV_TEACHER_FIRST_NAME=Dev
DEV_TEACHER_LAST_NAME=Teacher
DEV_TEACHER_NAME=Dev Teacher

DEV_STUDENT_EMAIL=student@example.com
DEV_STUDENT_PASSWORD=Password1!
DEV_STUDENT_FIRST_NAME=Demo
DEV_STUDENT_LAST_NAME=Student
DEV_STUDENT_NAME=Demo Student

# Optional curriculum manager seed values
CURRICULUM_MANAGER_EMAIL=curriculum.manager@example.com
CURRICULUM_MANAGER_PASSWORD=Password1!
CURRICULUM_MANAGER_NAME=Curriculum Manager

# Manual admin bootstrap (`pnpm run seed:admin` in packages/database)
# Prefer CURRICULUM_SEED_ADMIN_*; falls back to CURRICULUM_MANAGER_* above.
# CURRICULUM_SEED_ADMIN_EMAIL=you@example.com
# CURRICULUM_SEED_ADMIN_PASSWORD=change-me-8-chars-min
# CURRICULUM_SEED_ADMIN_NAME=Your Name

# Optional content import path
DATA_DIR=./data/content
